# SPA na raiz do domínio (obrigatório para este projeto)
VITE_BASE_PATH=/

# Supabase (obrigatório) — lidas em build (import.meta.env); independentes do nome da pasta
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Opcional: email do superadmin (não aparece na lista de barbeiros)
VITE_SUPERADMIN_EMAIL=

# Opcional: email com acesso de admin (além de role admin/superadmin no perfil)
VITE_ADMIN_EMAIL=
